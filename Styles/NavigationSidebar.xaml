<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar is always navy regardless of light/dark theme -->
    <SolidColorBrush x:Key="SidebarBrush"       Color="#FF14213D" />
    <SolidColorBrush x:Key="SidebarHoverBrush"  Color="#FF1C2E4A" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#FF1C2E4A" />

    <!-- Nav item button: icon + label, 44px min height -->
    <Style x:Key="NavItem" TargetType="Button">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="Foreground"       Value="#FFA0AEC0" />
        <Setter Property="BorderThickness"  Value="3,0,0,0" />
        <Setter Property="BorderBrush"      Value="Transparent" />
        <Setter Property="MinHeight"        Value="44" />
        <Setter Property="Padding"          Value="16,0" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource SidebarHoverBrush}" />
                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Active nav item: amber left border, lighter navy background, white text -->
    <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
        <Setter Property="Background"  Value="{StaticResource SidebarActiveBrush}" />
        <Setter Property="Foreground"  Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="#FFFCA311" />
    </Style>

    <!-- Header bar at top of content area -->
    <Style x:Key="HeaderBar" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource BackgroundBrush}" />
        <Setter Property="BorderBrush"      Value="{DynamicResource ThemeBorderBrush}" />
        <Setter Property="BorderThickness"  Value="0,0,0,1" />
        <Setter Property="Padding"          Value="24,0" />
        <Setter Property="Height"           Value="56" />
    </Style>

</ResourceDictionary>
