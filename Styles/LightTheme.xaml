<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <Color x:Key="ColorBackground">#FFFFFFFF</Color>
    <Color x:Key="ColorSurface">#FFE5E5E5</Color>
    <!-- SurfaceElevated intentionally matches Background in light theme;
         elevation is conveyed by CardShadowOpacity rather than a color shift. -->
    <Color x:Key="ColorSurfaceElevated">#FFFFFFFF</Color>
    <Color x:Key="ColorTextPrimary">#FF000000</Color>
    <Color x:Key="ColorTextSecondary">#FF4A4A4A</Color>
    <Color x:Key="ColorBorder">#FFD0D0D0</Color>

    <SolidColorBrush x:Key="BackgroundBrush"        Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="{StaticResource ColorSurfaceElevated}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource ColorTextSecondary}" />
    <!-- Named ThemeBorderBrush to avoid collision with WPF's implicit BorderBrush property name -->
    <SolidColorBrush x:Key="ThemeBorderBrush"       Color="{StaticResource ColorBorder}" />

    <sys:Double x:Key="CardShadowOpacity">0.08</sys:Double>
</ResourceDictionary>
