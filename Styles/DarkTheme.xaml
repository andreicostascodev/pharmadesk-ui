<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <Color x:Key="ColorBackground">#FF000000</Color>
    <Color x:Key="ColorSurface">#FF14213D</Color>
    <!-- SurfaceElevated is slightly lighter than Surface to create layering depth in dark mode -->
    <Color x:Key="ColorSurfaceElevated">#FF1C2E4A</Color>
    <Color x:Key="ColorTextPrimary">#FFFFFFFF</Color>
    <Color x:Key="ColorTextSecondary">#FFA0AEC0</Color>
    <Color x:Key="ColorBorder">#FF2D3F5C</Color>

    <SolidColorBrush x:Key="BackgroundBrush"        Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="{StaticResource ColorSurfaceElevated}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource ColorTextSecondary}" />
    <!-- Named ThemeBorderBrush to avoid collision with WPF's implicit BorderBrush property name -->
    <SolidColorBrush x:Key="ThemeBorderBrush"       Color="{StaticResource ColorBorder}" />

    <sys:Double x:Key="CardShadowOpacity">0.40</sys:Double>
</ResourceDictionary>
