<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Mode Palette -->
    <Color x:Key="DarkBg">#FF0F0F0F</Color>
    <Color x:Key="CardBg">#FF1A1A1A</Color>
    <Color x:Key="AccentRed">#FFE11D48</Color>
    <Color x:Key="AccentRedLight">#80E11D48</Color>
    <Color x:Key="TextWhite">#FFFFFFFF</Color>
    <Color x:Key="TextGray">#FFB3B3B3</Color>
    <Color x:Key="BorderDark">#FF2A2A2A</Color>
    
    <!-- Legacy Colors (backward compatibility) -->
    <Color x:Key="PrimaryColor">#FFE11D48</Color>
    <Color x:Key="AccentColor">#FFE11D48</Color>
    <Color x:Key="SurfaceColor">#FF1A1A1A</Color>
    <Color x:Key="SoftSurfaceColor">#FF2A2A2A</Color>
    <Color x:Key="TextColor">#FFFFFFFF</Color>
    <Color x:Key="MutedTextColor">#FFB3B3B3</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{StaticResource BorderDark}" />
    <SolidColorBrush x:Key="AccentRedLightBrush" Color="{StaticResource AccentRedLight}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="SoftSurfaceBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextWhite}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource TextGray}" />
    <SolidColorBrush x:Key="DarkBgBrush" Color="{StaticResource DarkBg}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderDark}" />
    
    <!-- Effects -->
    <DropShadowEffect x:Key="SoftShadow" BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000" />
    <DropShadowEffect x:Key="HighShadow" BlurRadius="32" ShadowDepth="8" Opacity="0.6" Color="#000000" />
    
    <!-- Animations -->
    <Storyboard x:Key="FadeInStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" />
    </Storyboard>
    
    <Storyboard x:Key="ScaleUpHoverStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1.0" To="1.03" Duration="0:0:0.3" />
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1.0" To="1.03" Duration="0:0:0.3" />
    </Storyboard>
    
    <Storyboard x:Key="ScaleDownHoverStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1.03" To="1.0" Duration="0:0:0.2" />
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1.03" To="1.0" Duration="0:0:0.2" />
    </Storyboard>
    
    <!-- Global TextBlock Style -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>
    
    <!-- TextBox Dark Style -->
    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="0,4,0,10" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
    </Style>
    
    <!-- ComboBox Dark Style -->
    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="0,4,0,10" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    </Style>
    
    <!-- Primary Button Style -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect" Value="{StaticResource HighShadow}" />
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Ghost Button Style (Secondary) -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    
    <!-- Card Style (Dark Theme) -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
    </Style>

    <!-- Large table performance defaults -->
    <Style TargetType="DataGrid">
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <!-- Image rendering defaults for product-heavy screens -->
    <Style TargetType="Image">
        <Setter Property="RenderOptions.BitmapScalingMode" Value="LowQuality" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
    
    <!-- Product Card Hover Style -->
    <Style x:Key="ProductCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="6" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentRedLightBrush}" />
                <Setter Property="Effect" Value="{StaticResource HighShadow}" />
                <Trigger.EnterActions>
                    <BeginStoryboard Storyboard="{StaticResource ScaleUpHoverStoryboard}" />
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard Storyboard="{StaticResource ScaleDownHoverStoryboard}" />
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- View Background -->
    <Style x:Key="ViewBackground" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource DarkBgBrush}" />
    </Style>
    
</ResourceDictionary>
