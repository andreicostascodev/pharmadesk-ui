<Page x:Class="PharmaDesk.Views.OrderHistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
            <TextBlock Text="Order History" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BentoCardStyle}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: order info -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="13" FontFamily="Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="#"/><Run Text="{Binding OrderId}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ItemsSummary}" FontSize="14" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding TimeAgo}" FontSize="12" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Center: total -->
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="16,0"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <Run Text="lei "/><Run Text="{Binding Total, StringFormat=N2}"/>
                                </TextBlock>

                                <!-- Right: status pill -->
                                <Border Grid.Column="2" VerticalAlignment="Center"
                                        CornerRadius="12" Padding="12,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33FCA311"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Completed">
                                                    <Setter Property="Background" Value="#3322C55E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#33EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFFCA311"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#FF22C55E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#FFEF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Page>
