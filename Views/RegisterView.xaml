<Window x:Class="PharmaDesk.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PharmaDesk — Register"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: navy brand panel -->
        <Border Grid.Column="0" Background="#FF14213D">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="64" Height="64" Fill="#FFFCA311" Margin="0,0,0,24" />
                <TextBlock Text="PharmaDesk" Foreground="White"
                           FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                           TextAlignment="Center" />
                <TextBlock Text="Join PharmaDesk today."
                           Foreground="#FFA0AEC0" FontFamily="Segoe UI" FontSize="14"
                           TextAlignment="Center" Margin="0,12,0,0"
                           TextWrapping="Wrap" MaxWidth="260" />
            </StackPanel>
        </Border>

        <!-- Right: registration form -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <StackPanel VerticalAlignment="Center" Margin="48,0">
                <TextBlock Text="Create account" Style="{StaticResource PageTitle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Fill in your details to get started"
                           Style="{StaticResource CardLabel}" Margin="0,0,0,32" />

                <TextBlock Text="Full Name" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                         BorderThickness="1" Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14" Margin="0,0,0,16" />

                <TextBlock Text="Email" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                         BorderThickness="1" Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14" Margin="0,0,0,16" />

                <TextBlock Text="Username" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                         BorderThickness="1" Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14" Margin="0,0,0,16" />

                <TextBlock Text="Password" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <PasswordBox x:Name="TxtPassword" Height="40"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="1" Padding="12,0"
                             VerticalContentAlignment="Center"
                             FontSize="14" Margin="0,0,0,16"
                             PasswordChanged="TxtPassword_PasswordChanged"/>

                <TextBlock Text="{Binding Message}" Foreground="#FFEF4444"
                           FontSize="12" Margin="0,0,0,16"
                           Visibility="{Binding Message, Converter={StaticResource NotNullConverter}}"/>

                <Button Content="Create Account" Style="{StaticResource PrimaryButton}"
                        Height="44" HorizontalAlignment="Stretch"
                        Command="{Binding RegisterCommand}" />

                <TextBlock Margin="0,20,0,0" TextAlignment="Center">
                    <Run Text="Already have an account? "
                         Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Hyperlink Command="{Binding DataContext.GoLoginCommand, RelativeSource={RelativeSource AncestorType=Window}}">Sign in</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
