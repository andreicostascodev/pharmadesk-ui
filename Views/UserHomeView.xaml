<Page x:Class="PharmaDesk.Views.UserHomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="clr-namespace:PharmaDesk.Views"
      Background="{DynamicResource BackgroundBrush}">
    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Browse Products" Style="{StaticResource PageTitle}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Search bar -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="1" Padding="12,0"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Search icon -->
                        <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <!-- Note: use Path/SVG icon in production; TextBlock emoji acceptable for now -->
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="44" BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Featured promotion banner -->
                <Border Height="80" CornerRadius="12" ClipToBounds="True"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFCA311" Offset="0"/>
                            <GradientStop Color="#FFE8940A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="Featured Products — Up to 30% Off"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Category filter pills — data-bound from Categories collection -->
                <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton Content="{Binding}"
                                          Style="{StaticResource CategoryPill}"
                                          Margin="0,0,8,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Products grid -->
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:ProductCard DataContext="{Binding}" Margin="6"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
