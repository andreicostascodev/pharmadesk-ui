<Page x:Class="PharmaDesk.Views.CategoryManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:PharmaDesk.Helpers"
      Background="{DynamicResource BackgroundBrush}">
    <Page.Resources>
        <helpers:FirstLetterConverter x:Key="FirstLetterConverter"/>
    </Page.Resources>
    <Grid>
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
                <TextBlock Text="Categories" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
            </Border>

            <!-- Category card grid -->
            <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BentoCardStyle}"
                                    Width="200" Margin="0,0,12,12"
                                    Cursor="Hand">
                                <StackPanel>
                                    <!-- Category icon / initial circle -->
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="#22FCA311" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Name, Converter={StaticResource FirstLetterConverter}}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="#FFFCA311"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <!-- Name -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,4"/>
                                    <!-- Item count -->
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
                                        <Run Text="{Binding Medicines.Count}"/><Run Text=" products"/>
                                    </TextBlock>
                                    <!-- Edit action -->
                                    <Button Content="Edit" Style="{StaticResource GhostButton}" Margin="0,12,0,0"
                                            HorizontalAlignment="Left" Height="28"
                                            Command="{Binding DataContext.EditCategoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- FAB: Add Category — amber, bottom-right -->
        <Button Content="+ Add Category" Style="{StaticResource PrimaryButton}"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,32,32"
                Width="160" Height="44"
                Command="{Binding AddCategoryCommand}"/>
    </Grid>
</Page>
