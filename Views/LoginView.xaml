<Window x:Class="PharmaDesk.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PharmaDesk — Login"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: navy brand panel -->
        <Border Grid.Column="0" Background="#FF14213D">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="64" Height="64" Fill="#FFFCA311" Margin="0,0,0,24" />
                <TextBlock Text="PharmaDesk" Foreground="White"
                           FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                           TextAlignment="Center" />
                <TextBlock Text="Pharmacy management, simplified."
                           Foreground="#FFA0AEC0" FontFamily="Segoe UI" FontSize="14"
                           TextAlignment="Center" Margin="0,12,0,0"
                           TextWrapping="Wrap" MaxWidth="260" />
            </StackPanel>
        </Border>

        <!-- Right: form panel -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <StackPanel VerticalAlignment="Center" Margin="48,0">
                <TextBlock Text="Welcome back" Style="{StaticResource PageTitle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Sign in to your account"
                           Style="{StaticResource CardLabel}" Margin="0,0,0,32" />

                <TextBlock Text="Email / Username" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                         BorderThickness="1" Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14" Margin="0,0,0,16" />

                <TextBlock Text="Password" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                <!-- PasswordBox cannot bind directly; use a helper via code-behind -->
                <PasswordBox x:Name="TxtPassword" Height="40"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="1" Padding="12,0"
                             VerticalContentAlignment="Center"
                             FontSize="14" Margin="0,0,0,8"
                             PasswordChanged="TxtPassword_PasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFEF4444"
                           FontSize="12" Margin="0,0,0,16"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullConverter}}"/>

                <Button Content="Sign In" Style="{StaticResource PrimaryButton}"
                        Height="44" HorizontalAlignment="Stretch"
                        Command="{Binding LoginCommand}" />

                <TextBlock Margin="0,20,0,0" TextAlignment="Center">
                    <Run Text="Don't have an account? "
                         Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Hyperlink Command="{Binding DataContext.GoRegisterCommand, RelativeSource={RelativeSource AncestorType=Window}}">Register</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
