<Page x:Class="PharmaDesk.Views.AdminOrdersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Orders" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Export" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportCommand}"/>
            </Grid>
        </Border>

        <DockPanel Margin="24">
            <!-- Status filter tabs -->
            <Border DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <!-- All tab -->
                    <Button Command="{Binding FilterCommand}" CommandParameter="All"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter, StringFormat={}{0}}" Value="All">
                                        <Setter Property="Foreground" Value="#FFFCA311"/>
                                        <Setter Property="BorderBrush" Value="#FFFCA311"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="All" VerticalAlignment="Center"/>
                            <Border CornerRadius="10" Background="#FFFCA311" Margin="6,0,0,0" Padding="6,1">
                                <TextBlock Text="{Binding AllCount}" FontSize="11" Foreground="#FF000000"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <!-- Pending tab -->
                    <Button Command="{Binding FilterCommand}" CommandParameter="Pending"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter, StringFormat={}{0}}" Value="Pending">
                                        <Setter Property="Foreground" Value="#FFFCA311"/>
                                        <Setter Property="BorderBrush" Value="#FFFCA311"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pending" VerticalAlignment="Center"/>
                            <Border CornerRadius="10" Background="#FFFCA311" Margin="6,0,0,0" Padding="6,1">
                                <TextBlock Text="{Binding PendingCount}" FontSize="11" Foreground="#FF000000"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <!-- Completed tab -->
                    <Button Command="{Binding FilterCommand}" CommandParameter="Completed"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter, StringFormat={}{0}}" Value="Completed">
                                        <Setter Property="Foreground" Value="#FF22C55E"/>
                                        <Setter Property="BorderBrush" Value="#FF22C55E"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Completed" VerticalAlignment="Center"/>
                            <Border CornerRadius="10" Background="#FFFCA311" Margin="6,0,0,0" Padding="6,1">
                                <TextBlock Text="{Binding CompletedCount}" FontSize="11" Foreground="#FF000000"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <!-- Cancelled tab -->
                    <Button Command="{Binding FilterCommand}" CommandParameter="Cancelled">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter, StringFormat={}{0}}" Value="Cancelled">
                                        <Setter Property="Foreground" Value="#FFEF4444"/>
                                        <Setter Property="BorderBrush" Value="#FFEF4444"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cancelled" VerticalAlignment="Center"/>
                            <Border CornerRadius="10" Background="#FFFCA311" Margin="6,0,0,0" Padding="6,1">
                                <TextBlock Text="{Binding CancelledCount}" FontSize="11" Foreground="#FF000000"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Orders DataGrid -->
            <DataGrid ItemsSource="{Binding FilteredOrders}"
                      SelectedItem="{Binding SelectedOrder}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      RowBackground="{DynamicResource BackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource ThemeBorderBrush}"
                      BorderThickness="1"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource ThemeBorderBrush}"
                      ColumnHeaderHeight="40"
                      RowHeight="52">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Order Number (monospace) -->
                    <DataGridTemplateColumn Header="Order ID" Width="120" SortMemberPath="OrderNumber" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13"
                                           Text="{Binding OrderNumber}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Customer -->
                    <DataGridTextColumn Header="Customer" Binding="{Binding User.FullName}" Width="*" CanUserSort="True"/>

                    <!-- Items count -->
                    <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="60" CanUserSort="True"/>

                    <!-- Total -->
                    <DataGridTemplateColumn Header="Total" Width="100" SortMemberPath="GrandTotal" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="lei "/><Run Text="{Binding GrandTotal, StringFormat=N2}"/>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="120" SortMemberPath="Status" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33FCA311"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Completed">
                                                    <Setter Property="Background" Value="#3322C55E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Livrata">
                                                    <Setter Property="Background" Value="#3322C55E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#33EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Anulata">
                                                    <Setter Property="Background" Value="#33EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFFCA311"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#FF22C55E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Livrata">
                                                        <Setter Property="Foreground" Value="#FF22C55E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#FFEF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status, StringFormat={}{0}}" Value="Anulata">
                                                        <Setter Property="Foreground" Value="#FFEF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat='dd MMM yyyy'}" Width="120" CanUserSort="True"/>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="200" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <Button Content="View" Style="{StaticResource GhostButton}"
                                            Margin="0,0,8,0" Height="32"
                                            Command="{Binding DataContext.ViewOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Update Status" Style="{StaticResource SecondaryButton}"
                                            Height="32"
                                            Command="{Binding DataContext.UpdateStatusCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Page>
