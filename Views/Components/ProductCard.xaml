<UserControl x:Class="PharmaDesk.Views.Components.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200">
    <!-- Border acts as the card -->
    <Border CornerRadius="12"
            Background="{DynamicResource SurfaceElevatedBrush}"
            BorderThickness="1"
            Cursor="Hand">
        <!-- Trigger: hover → amber border + deeper shadow -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.10" ShadowDepth="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#FFFCA311"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#000000" BlurRadius="16" Opacity="0.18" ShadowDepth="2"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <!-- Image: 160px height, rounded top via ClipToBounds on parent -->
            <Border Height="160" CornerRadius="12,12,0,0" ClipToBounds="True">
                <Image x:Name="ProductImage" Stretch="UniformToFill"
                       Source="{Binding ImagePath, FallbackValue='Assets/placeholder.png'}"/>
            </Border>
            <!-- Content -->
            <StackPanel Margin="12,10,12,12">
                <!-- Product name -->
                <TextBlock Text="{Binding Name}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap" MaxHeight="42"
                           Margin="0,0,0,6"/>
                <!-- Category pill: amber outlined, 11px -->
                <Border CornerRadius="10" BorderBrush="#FFFCA311" BorderThickness="1"
                        HorizontalAlignment="Left" Padding="8,2"
                        Margin="0,0,0,6">
                    <TextBlock Text="{Binding Category}"
                               FontSize="11" Foreground="#FFFCA311"/>
                </Border>
                <!-- Price -->
                <TextBlock FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,6">
                    <Run Text="lei "/>
                    <Run Text="{Binding Price, StringFormat=N2}"/>
                </TextBlock>
                <!-- Add to Cart button -->
                <Button Content="Add to Cart"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddToCartCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
