<UserControl x:Class="PharmaDesk.Views.Components.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Cursor="Hand">
    <Border Style="{StaticResource ProductCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Product Image -->
            <Grid Grid.Row="0" Height="150" Margin="0,0,0,12">
                <Image Source="{Binding ImageUrl, FallbackValue='pack://application:,,,/Assets/Products/placeholder.png'}"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="LowQuality"
                       SnapsToDevicePixels="True"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                    </Image.RenderTransform>
                </Image>
                <!-- New Badge -->
                <Border CornerRadius="4" 
                        Background="#FFE11D48" 
                        Padding="6,3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8">
                    <TextBlock Text="NEW" 
                               Foreground="White" 
                               FontWeight="Bold" 
                               FontSize="10"
                               Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Border>
                <!-- Discount Badge -->
                <Border CornerRadius="20" 
                        Background="#FFE11D48" 
                        Padding="8,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="8"
                        Visibility="{Binding IsPromotion, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="-" Foreground="White" FontWeight="Bold" Margin="0,0,2,0"/>
                        <TextBlock Text="{Binding DiscountPercent, StringFormat={}{0}%}" 
                                   Foreground="White" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Product Info -->
            <StackPanel Grid.Row="1">
                <!-- Name -->
                <TextBlock Text="{Binding Name}" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#FFFFFFFF"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="36"
                           TextWrapping="Wrap" />
                
                <!-- Generic Name (if exists) -->
                <TextBlock Text="{Binding GenericName}" 
                           FontSize="11" 
                           Foreground="#FFB3B3B3"
                           TextTrimming="CharacterEllipsis" 
                           Margin="0,6,0,0"
                           Visibility="{Binding GenericName, Converter={StaticResource NotNullConverter}}" />
                
                <!-- Strength & Dosage -->
                <TextBlock Text="{Binding Strength}" 
                           FontSize="11" 
                           Foreground="#FFB3B3B3" />
                
                <!-- Stock Status -->
                <TextBlock Text="Stock scazut!" 
                           FontSize="10" 
                           Foreground="#FFE11D48"
                           FontWeight="SemiBold"
                           Margin="0,6,0,0"
                           Visibility="{Binding StockQuantity, Converter={StaticResource StockWarningConverter}}" />
            </StackPanel>

            <!-- Price & Action -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <!-- Price -->
                    <TextBlock Text="{Binding UnitPrice, StringFormat='${0:F2}'}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#FFE11D48" />
                    
                    <!-- Discount Price (if promo) -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsPromotion, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding OriginalPrice, StringFormat={}${0:F2}}" 
                                   FontSize="11" 
                                   Foreground="#FFB3B3B3"
                                   TextDecorations="Strikethrough" />
                        <TextBlock Text="You save!" 
                                   FontSize="10" 
                                   Foreground="#FF0FD000" 
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Rating -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="★" Foreground="#FFE11D48" FontSize="12"/>
                    <TextBlock Text="{Binding Rating, StringFormat={}{0:F1}}" 
                               Foreground="#FFFFFFFF" 
                               FontSize="11" 
                               VerticalAlignment="Center"
                               Margin="2,0,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
