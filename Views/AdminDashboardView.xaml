<Page x:Class="PharmaDesk.Views.AdminDashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:vm="clr-namespace:PharmaDesk.ViewModels"
      xmlns:conv="clr-namespace:PharmaDesk.Converters"
      Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <conv:StatusToBrushConverter   x:Key="StatusToBrushConverter" />
        <conv:ProgressToWidthConverter x:Key="ProgressToWidthConverter" />
    </Page.Resources>

    <Page.DataContext>
        <vm:AdminDashboardViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>

            <!-- ── Row 1: KPI Cards ── -->
            <UniformGrid Columns="4" Margin="0,0,0,12">

                <!-- Total Products -->
                <Border Style="{StaticResource BentoCardStyle}" Margin="0,0,6,0"
                        BorderBrush="{StaticResource AccentBrush}">
                    <StackPanel>
                        <TextBlock Text="TOTAL PRODUCTS" Style="{StaticResource CardLabel}" />
                        <TextBlock Text="{Binding TotalProducts}" Style="{StaticResource KpiValue}"
                                   Margin="0,8,0,4" />
                        <TextBlock Text="↑ 5.2%" FontSize="13" Foreground="#22C55E" Margin="0,2,0,0" />
                        <lvc:CartesianChart Series="{Binding ProductsTrend}"
                                           Height="40" Margin="0,4,0,0"
                                           XAxes="{x:Null}" YAxes="{x:Null}"
                                           LegendPosition="Hidden" TooltipPosition="Hidden" />
                    </StackPanel>
                </Border>

                <!-- Orders Today -->
                <Border Style="{StaticResource BentoCardStyle}" Margin="6,0,6,0"
                        BorderBrush="{StaticResource AccentBrush}">
                    <StackPanel>
                        <TextBlock Text="ORDERS TODAY" Style="{StaticResource CardLabel}" />
                        <TextBlock Text="{Binding OrdersToday}" Style="{StaticResource KpiValue}"
                                   Margin="0,8,0,4" />
                        <TextBlock Text="↑ 8.3%" FontSize="13" Foreground="#22C55E" Margin="0,2,0,0" />
                        <lvc:CartesianChart Series="{Binding OrdersTrend}"
                                           Height="40" Margin="0,4,0,0"
                                           XAxes="{x:Null}" YAxes="{x:Null}"
                                           LegendPosition="Hidden" TooltipPosition="Hidden" />
                    </StackPanel>
                </Border>

                <!-- Low Stock Alerts -->
                <Border Style="{StaticResource BentoCardStyle}" Margin="6,0,6,0"
                        BorderBrush="{StaticResource DangerBrush}">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ALERTS" Style="{StaticResource CardLabel}" />
                        <TextBlock Text="{Binding LowStockCount}" Style="{StaticResource KpiValue}"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,8,0,4" />
                        <TextBlock Text="↓ 25.0%" FontSize="13" Foreground="#EF4444" Margin="0,2,0,0" />
                        <lvc:CartesianChart Series="{Binding LowStockTrend}"
                                           Height="40" Margin="0,4,0,0"
                                           XAxes="{x:Null}" YAxes="{x:Null}"
                                           LegendPosition="Hidden" TooltipPosition="Hidden" />
                    </StackPanel>
                </Border>

                <!-- Revenue Today -->
                <Border Style="{StaticResource BentoCardStyle}" Margin="6,0,0,0"
                        BorderBrush="{StaticResource SuccessBrush}">
                    <StackPanel>
                        <TextBlock Text="REVENUE TODAY" Style="{StaticResource CardLabel}" />
                        <TextBlock Style="{StaticResource KpiValue}" Margin="0,8,0,4">
                            <Run Text="lei " FontSize="20" />
                            <Run Text="{Binding RevenueToday, StringFormat=N2}" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding RevenueTrendText}"
                                       Foreground="{StaticResource SuccessBrush}" FontSize="13" />
                            <TextBlock Text=" vs last month"
                                       Style="{StaticResource CardLabel}" Margin="4,0,0,0" />
                        </StackPanel>
                        <lvc:CartesianChart Series="{Binding RevenueTrend}"
                                           Height="40" Margin="0,4,0,0"
                                           XAxes="{x:Null}" YAxes="{x:Null}"
                                           LegendPosition="Hidden" TooltipPosition="Hidden" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Row 2: Revenue Chart + Donut ── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Revenue Bar Chart -->
                <Border Grid.Column="0" Style="{StaticResource BentoCardStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Revenue" Style="{StaticResource SectionHeading}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="7d"  Style="{StaticResource GhostButton}"
                                        Command="{Binding SetRangeCommand}"
                                        CommandParameter="7" />
                                <Button Content="30d" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SetRangeCommand}"
                                        CommandParameter="30" Margin="4,0" />
                                <Button Content="90d" Style="{StaticResource GhostButton}"
                                        Command="{Binding SetRangeCommand}"
                                        CommandParameter="90" />
                            </StackPanel>
                        </DockPanel>
                        <lvc:CartesianChart Series="{Binding RevenueChartSeries}"
                                           XAxes="{Binding RevenueXAxes}"
                                           YAxes="{Binding RevenueYAxes}"
                                           Height="240" LegendPosition="Hidden" />
                    </StackPanel>
                </Border>

                <!-- Order Status Donut -->
                <Border Grid.Column="2" Style="{StaticResource BentoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Order Status" Style="{StaticResource SectionHeading}"
                                   Margin="0,0,0,16" />
                        <Grid>
                            <lvc:PieChart Series="{Binding OrderStatusSeries}"
                                          Height="200" LegendPosition="Hidden"
                                          InitialRotation="-90" />
                            <TextBlock Text="{Binding TotalOrderCount}"
                                       Style="{StaticResource KpiValue}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Pending" Style="{StaticResource CardLabel}"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="—%" Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Completed" Style="{StaticResource CardLabel}"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="—%" Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource DangerBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Cancelled" Style="{StaticResource CardLabel}"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="—%" Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 3: Top Products + Recent Orders ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <!-- Top Selling Products -->
                <Border Grid.Column="0" Style="{StaticResource BentoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Top Products" Style="{StaticResource SectionHeading}"
                                   Margin="0,0,0,16" />
                        <ItemsControl ItemsSource="{Binding TopProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Rank, StringFormat='#{0}'}"
                                                   Style="{StaticResource CardLabel}"
                                                   VerticalAlignment="Center" />
                                        <Image Grid.Column="1" Source="{Binding ImagePath}"
                                               Width="36" Height="36"
                                               Stretch="UniformToFill" Margin="0,0,8,0" />
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <Grid Height="6" Margin="0,4,0,0" Width="160" HorizontalAlignment="Left">
                                                <Border Background="{DynamicResource ThemeBorderBrush}"
                                                        CornerRadius="3" />
                                                <Border Background="{StaticResource AccentBrush}"
                                                        CornerRadius="3"
                                                        HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <Binding Path="Progress"
                                                                 Converter="{StaticResource ProgressToWidthConverter}" />
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding UnitsSold}"
                                                   Style="{StaticResource MonoText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recent Orders Table -->
                <Border Grid.Column="2" Style="{StaticResource BentoCardStyle}" Padding="0">
                    <StackPanel>
                        <TextBlock Text="Recent Orders" Style="{StaticResource SectionHeading}"
                                   Margin="20,20,20,16" />
                        <DataGrid x:Name="RecentOrdersGrid"
                                  Style="{StaticResource PharmaDataGrid}"
                                  ColumnHeaderStyle="{StaticResource PharmaDataGridColumnHeader}"
                                  ItemsSource="{Binding RecentOrders}"
                                  MouseDoubleClick="RecentOrdersGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order ID"
                                    Binding="{Binding OrderId}"
                                    ElementStyle="{StaticResource MonoText}"
                                    Width="90" />
                                <DataGridTemplateColumn Header="Customer" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Background="{StaticResource NavyBrush}">
                                                    <TextBlock Text="{Binding Initials}"
                                                               Foreground="White" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{Binding Customer}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Items"
                                    Binding="{Binding ItemCount}" Width="50" />
                                <DataGridTextColumn Header="Total (lei)"
                                    Binding="{Binding Total, StringFormat=N2}" Width="90" />
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StatusBadge}"
                                                    Background="{Binding Status,
                                                        Converter={StaticResource StatusToBrushConverter}}">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Time"
                                    Binding="{Binding TimeAgo}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
