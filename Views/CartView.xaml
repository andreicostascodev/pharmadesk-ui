<Page x:Class="PharmaDesk.Views.CartView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
            <TextBlock Text="Shopping Cart" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
        </Border>

        <!-- Body: two columns -->
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: item list -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Cart item row card -->
                            <Border Style="{StaticResource BentoCardStyle}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Product image -->
                                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Width="72" Height="72">
                                        <Image Source="{Binding Medicine.ImageUrl, FallbackValue='Assets/placeholder.png'}"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <!-- Name + category -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Medicine.Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Medicine.Category.Name}" FontSize="12" Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <!-- Qty stepper -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                        <Button Content="&#x2212;" Style="{StaticResource GhostButton}" Width="32" Height="32"
                                                Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Quantity}" Width="32" TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Button Content="+" Style="{StaticResource GhostButton}" Width="32" Height="32"
                                                Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                    <!-- Row total -->
                                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="lei "/>
                                        <Run Text="{Binding LineTotal, StringFormat=N2}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- RIGHT: summary card (sticky) -->
            <Border Grid.Column="2" Style="{StaticResource BentoCardStyle}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Order Summary" Style="{StaticResource SectionHeading}" Margin="0,0,0,16"/>

                    <!-- Subtotal row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Subtotal" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                        <TextBlock Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14">
                            <Run Text="lei "/>
                            <Run Text="{Binding Subtotal, StringFormat=N2}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Delivery row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Delivery" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                        <TextBlock Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14">
                            <Run Text="lei "/>
                            <Run Text="{Binding DeliveryFee, StringFormat=N2}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource ThemeBorderBrush}" Margin="0,0,0,16"/>

                    <!-- Total row -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="lei "/>
                            <Run Text="{Binding Total, StringFormat=N2}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Checkout CTA -->
                    <Button Content="Checkout" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                            Command="{Binding CheckoutCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Page>
