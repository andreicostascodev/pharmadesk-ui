<Window x:Class="PharmaDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmaDesk.ViewModels"
        xmlns:views="clr-namespace:PharmaDesk.Views"
        Title="PharmaDesk" Height="820" Width="1280" MinHeight="700" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <!-- Keep ALL existing DataTemplate entries exactly as they were -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><views:LoginView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}"><views:RegisterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserHomeViewModel}"><views:UserHomeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CartViewModel}"><views:CartView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrderHistoryViewModel}"><views:OrderHistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}"><views:ProfileView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}"><views:AdminDashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductManagementViewModel}"><views:ProductManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoryManagementViewModel}"><views:CategoryManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}"><views:UserManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminOrdersViewModel}"><views:AdminOrdersView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditLogViewModel}"><views:AuditLogView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR — always navy ═══ -->
        <Border Grid.Column="0" Background="#FF14213D">
            <DockPanel>

                <!-- TOP: hamburger + logo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            HorizontalAlignment="Left" Margin="16,16,0,0"
                            Width="36" Height="36"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="☰" FontSize="20" Foreground="White"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="16,12,16,0"
                                Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Width="36" Height="36" CornerRadius="18" Background="#FFFCA311">
                            <TextBlock Text="P" FontSize="18" FontWeight="Bold" Foreground="#FF000000"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="PharmaDesk" FontSize="15" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- BOTTOM: theme + logout + avatar -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16">
                    <Border Height="1" Background="#FF2D3F5C" Margin="16,0,16,12"/>

                    <!-- Theme toggle -->
                    <Button Command="{Binding ToggleThemeCommand}"
                            HorizontalAlignment="Left" Margin="16,0,0,8"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Height="36">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☀" FontSize="16" Foreground="#FFFCA311" VerticalAlignment="Center"/>
                            <TextBlock Text=" Theme" Foreground="White" FontSize="13" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- Logout -->
                    <Button Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Left" Margin="16,0,0,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Height="36"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏻" FontSize="16" Foreground="#FFA0AEC0" VerticalAlignment="Center"/>
                            <TextBlock Text=" Logout" Foreground="#FFA0AEC0" FontSize="13" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- User avatar -->
                    <StackPanel Orientation="Horizontal" Margin="16,12,16,0"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
                        <Border Width="36" Height="36" CornerRadius="18" Background="#FFFCA311">
                            <TextBlock Text="U" FontSize="14" FontWeight="Bold" Foreground="#FF000000"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="White" FontSize="13"
                                   VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- NAV ITEMS -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">

                        <!-- Customer nav -->
                        <Button Command="{Binding GoHomeCommand}" Style="{StaticResource NavItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌂" FontSize="18" Width="24" TextAlignment="Center" Foreground="White"/>
                                <TextBlock Text=" Home" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding GoCartCommand}" Style="{StaticResource NavItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒" FontSize="16" Width="24" TextAlignment="Center"/>
                                <TextBlock Text=" Cart" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding GoOrdersCommand}" Style="{StaticResource NavItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Width="24" TextAlignment="Center"/>
                                <TextBlock Text=" Orders" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding GoProfileCommand}" Style="{StaticResource NavItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="16" Width="24" TextAlignment="Center"/>
                                <TextBlock Text=" Profile" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Admin divider + nav -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanManageMedicines}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Height="1" Background="#FF2D3F5C" Margin="16,12,16,8"/>
                            <Button Command="{Binding GoAdminDashboardCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊞" FontSize="18" Width="24" TextAlignment="Center" Foreground="White"/>
                                    <TextBlock Text=" Dashboard" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding GoProductsCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💊" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock Text=" Products" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding GoCategoriesCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊟" FontSize="18" Width="24" TextAlignment="Center" Foreground="White"/>
                                    <TextBlock Text=" Categories" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding GoAdminOrdersCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock Text=" Orders" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Super-admin nav -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Height="1" Background="#FF2D3F5C" Margin="16,12,16,8"/>
                            <Button Command="{Binding GoUsersCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock Text=" Users" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding GoReportsCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock Text=" Reports" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding GoAuditCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗋" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock Text=" Audit Log" FontSize="13" Foreground="White" VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="0"/>

            <!-- Toast notification -->
            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="#FFFCA311" BorderThickness="1"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="24"
                    Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ToastMessage}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </Grid>
</Window>
