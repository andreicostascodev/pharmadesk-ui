<Window x:Class="PharmaDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PharmaDesk" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="#FF14213D">
            <DockPanel>

                <!-- TOP: hamburger + logo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                    <!-- Hamburger toggle -->
                    <Button x:Name="BtnToggle" Click="BtnToggle_Click"
                            HorizontalAlignment="Left" Margin="16,16,0,0"
                            Width="36" Height="36"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Toggle sidebar">
                        <TextBlock Text="☰" FontSize="20" Foreground="White"/>
                    </Button>

                    <!-- Logo row (hidden when collapsed) -->
                    <StackPanel x:Name="LogoPanel" Orientation="Horizontal"
                                Margin="16,16,16,0">
                        <!-- Amber circle logo -->
                        <Border Width="36" Height="36" CornerRadius="18" Background="#FFFCA311">
                            <TextBlock Text="P" FontSize="18" FontWeight="Bold" Foreground="#FF000000"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <!-- App name -->
                        <TextBlock x:Name="AppNameLabel" Text="PharmaDesk"
                                   FontSize="16" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- BOTTOM: avatar + theme toggle + logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16">
                    <!-- Divider -->
                    <Border Height="1" Background="#FF2D3F5C" Margin="16,0,16,12"/>

                    <!-- Theme toggle -->
                    <Button x:Name="BtnTheme" Click="BtnTheme_Click"
                            HorizontalAlignment="Left" Margin="16,0,0,8"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Height="36">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ThemeIcon" Text="☀" FontSize="16" Foreground="#FFFCA311"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ThemeLabel" Text=" Light Mode"
                                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Logout -->
                    <Button Click="BtnLogout_Click"
                            HorizontalAlignment="Left" Margin="16,0,0,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Height="36">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏻" FontSize="16" Foreground="#FFA0AEC0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LogoutLabel" Text=" Logout"
                                       Foreground="#FFA0AEC0" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- User avatar row -->
                    <StackPanel Orientation="Horizontal" Margin="16,12,16,0">
                        <Border Width="36" Height="36" CornerRadius="18" Background="#FFFCA311">
                            <TextBlock x:Name="UserInitials" Text="U"
                                       FontSize="14" FontWeight="Bold" Foreground="#FF000000"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="UserNameLabel" Text="User"
                                   Foreground="White" FontSize="13" VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- NAV ITEMS (middle, scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="NavPanel" Margin="0,8,0,0">

                        <!-- Admin nav items (shown/hidden based on role) -->
                        <StackPanel x:Name="AdminNav">
                            <Button x:Name="NavDashboard" Click="NavDashboard_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊞" FontSize="18" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblDashboard" Text=" Dashboard" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavOrders" Click="NavOrders_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblOrders" Text=" Orders" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavProducts" Click="NavProducts_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💊" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblProducts" Text=" Products" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavCategories" Click="NavCategories_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊟" FontSize="18" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblCategories" Text=" Categories" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavUsers" Click="NavUsers_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblUsers" Text=" Users" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavReports" Click="NavReports_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblReports" Text=" Reports" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavAudit" Click="NavAudit_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗋" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblAudit" Text=" Audit Log" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Customer nav items -->
                        <StackPanel x:Name="CustomerNav" Visibility="Collapsed">
                            <Button x:Name="NavHome" Click="NavHome_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⌂" FontSize="18" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblHome" Text=" Home" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavCart" Click="NavCart_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblCart" Text=" Cart" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavOrderHistory" Click="NavOrderHistory_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblOrderHistory" Text=" Order History" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavProfile" Click="NavProfile_Click"
                                    Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="16" Width="24" TextAlignment="Center"/>
                                    <TextBlock x:Name="LblProfile" Text=" Profile" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT FRAME ═══ -->
        <Frame x:Name="ContentFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
